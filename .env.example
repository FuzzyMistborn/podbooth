# ── LiveKit ────────────────────────────────────────────────────────────────────
# API key/secret pair — must exactly match the `keys` block in livekit/livekit.yaml.
# Use any random alphanumeric strings; these are never exposed to clients.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# Internal URL the app uses to reach the LiveKit container.
# If you're using this compose stack, keep ws://livekit:7880 as-is.
LIVEKIT_URL=ws://livekit:7880

# Public WebSocket URL that *browsers* connect to for WebRTC signalling.
# Must be reachable by all participants. Usually your server's hostname on port 7880.
LIVEKIT_PUBLIC_URL=wss://your-server.example.com:7880

# ── TURN / coturn ──────────────────────────────────────────────────────────────
# IP address that clients can reach the coturn server on (your server's LAN or public IP).
TURN_EXTERNAL_IP=192.168.1.10

# TURN credentials — set to anything, just keep them consistent with livekit/livekit.yaml.
TURN_USER=turnuser
TURN_PASSWORD=change-me

# ── App ────────────────────────────────────────────────────────────────────────
# Secret used to sign session cookies. Generate one with:
#   openssl rand -base64 32
SECRET_KEY=change-me

# Public-facing URL of the app (used for share links and cookie security flags).
BASE_URL=https://your-server.example.com

# Path inside the container where recordings are stored. Matches the volume mount.
RECORDINGS_DIR=/recordings

# Timezone for session timestamps and recording folder dates.
# Use a standard tz database name: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Defaults to UTC if not set.
TZ=UTC

# Optional: restrict the host UI behind a password. Leave blank (or remove) to disable.
# HOST_PASSWORD=

# Optional: enables the machine-to-machine session API (POST/DELETE /api/session).
# Leave blank to disable the API entirely. Generate with: openssl rand -base64 32
# API_KEY=

# ── Transcription (WhisperX) ───────────────────────────────────────────────────
# Set WHISPERX_API_URL to enable automatic transcription of recorded audio.
# Point it at a running whisperx-api container (https://github.com/macnow/whisperx-api).
# Leave unset (or empty) to disable transcription entirely.
# WHISPERX_API_URL=http://whisperx:8000

# Faster-Whisper model to use. Defaults to large-v3-turbo.
# WHISPERX_MODEL=large-v3-turbo

# Force a language code (e.g. "en", "fr"). Leave unset for auto-detection.
# WHISPERX_LANGUAGE=

# ── Nextcloud upload (WebDAV) ──────────────────────────────────────────────────
# Set NEXTCLOUD_URL to enable uploading recordings to Nextcloud after a session.
# NEXTCLOUD_URL=https://nextcloud.example.com
# NEXTCLOUD_USER=myuser
# NEXTCLOUD_PASSWORD=mypassword
# Folder inside your Nextcloud to upload into. Defaults to "PodBooth".
# NEXTCLOUD_UPLOAD_PATH=PodBooth

# ── FileBrowser upload ─────────────────────────────────────────────────────────
# Set FILEBROWSER_URL to enable uploading recordings to a FileBrowser instance.
# FILEBROWSER_URL=https://files.example.com
# FILEBROWSER_USER=admin
# FILEBROWSER_PASSWORD=mypassword
# Folder inside FileBrowser to upload into. Defaults to "PodBooth".
# FILEBROWSER_UPLOAD_PATH=PodBooth

# ── Cloudflare R2 upload (S3-compatible) ───────────────────────────────────────
# Set R2_ACCOUNT_ID + credentials to enable uploading to a Cloudflare R2 bucket.
# R2_ACCOUNT_ID=abcdef1234567890abcdef1234567890
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_ACCESS_KEY_SECRET=your-r2-access-key-secret
# R2_BUCKET=my-podbooth-bucket
# Folder prefix inside the bucket. Defaults to "PodBooth".
# R2_UPLOAD_PATH=PodBooth

# ── Backblaze B2 upload (S3-compatible) ────────────────────────────────────────
# Set B2_ENDPOINT_URL + credentials to enable uploading to a Backblaze B2 bucket.
# B2_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com
# B2_ACCESS_KEY_ID=your-b2-key-id
# B2_ACCESS_KEY_SECRET=your-b2-application-key
# B2_BUCKET=my-podbooth-bucket
# Folder prefix inside the bucket. Defaults to "PodBooth".
# B2_UPLOAD_PATH=PodBooth

# ── S3 object storage for editor delivery ──────────────────────────────────────
# Generic S3-compatible storage for the editor delivery pipeline (manifest + participant uploads).
# Supports Cloudflare R2, Backblaze B2, or any S3-compatible backend.
# S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY_ID=your-access-key-id
# S3_SECRET_ACCESS_KEY=your-secret-access-key
# S3_BUCKET_NAME=my-podbooth-bucket
# Public base URL for the bucket (custom domain or provider URL, no trailing slash).
# S3_PUBLIC_URL=https://files.example.com
# How many days editor links and presigned download URLs remain valid. Default: 7.
# S3_UPLOAD_EXPIRY_DAYS=7

# ── Outline wiki integration ───────────────────────────────────────────────────
# Set both vars to enable importing show notes from an Outline document into
# the studio notes field. A read-only API token is sufficient.
# OUTLINE_API_URL=https://wiki.example.com
# OUTLINE_API_KEY=ol_api_...

# ── Editor portal ──────────────────────────────────────────────────────────────
# Base URL of the editor portal. Editor links are formatted as
# {EDITOR_PORTAL_URL}/session/{id}?token={token}
# EDITOR_PORTAL_URL=https://editor.example.com
